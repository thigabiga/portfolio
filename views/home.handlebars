{{!-- WORK --}}
<div class="anchor" id="work"></div>
<div class="row-fluid top-row" id="workArtworkGrid">
    {{#each codeInfo}}
        <div class="col-xs-12 col-sm-6 col-md-4 grid-thumbnail-col">
            {{!-- <img class="grid-thumbnail" src="../../images/{{image}}" alt="{{alt}}" />
            <div class="overlay-color" data-id="{{id}}" id="overlay-{{id}}"></div> --}}
            <div data-id="{{id}}" id="text-{{id}}">{{title}}</div>
        </div>
    {{/each}}
</div>

{{!-- DESIGN PROJECTS --}}
<div class="row text-padding d-flex h2-padding justify-content-center" id="design">
    <div class="col-12 d-flex limit-width justify-content-center">
        <h2>Here's my design gallery.</h2>
    </div>
</div>
<div class="row" id="designArtworkGrid">
    {{#each designInfo}}
    <div class="col-xs-12 col-sm-6 col-md-4 grid-thumbnail-col">
        <img class="grid-thumbnail" src="../../images/{{image}}" alt="{{alt}}" />
        <div class="overlay-color" data-id="{{id}}" id="overlay-{{id}}"></div>
        <div class="overlay-text" data-id="{{id}}" id="text-{{id}}">{{title}}</div>
    </div>
    {{/each}}
</div>

